{
  "name": "migration-validator",
  "version": "1.0.0",
  "private": true,
  "description": "Cafe24 migration CSV validator for member and order data",
  "main": "dist/cli/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli/index.ts",
    "validate": "node dist/cli/index.js",
    "sample:member": "tsx src/cli/index.ts --type member --input ./samples/member.sample.csv --out ./reports/member-sample",
    "sample:order": "tsx src/cli/index.ts --type order --input ./samples/order.sample.csv --out ./reports/order-sample"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
